# Backend (ASP.NET Core), read as environment variables in production (e.g. Render),
# double underscores map to nested config sections (Jwt__SigningKey -> Jwt:SigningKey).
# For local development, copy backend/appsettings.Development.json.example to
# backend/appsettings.Development.json instead and edit the values there.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=identity_habits;Username=postgres;Password=postgres
Jwt__SigningKey=replace-with-a-long-random-secret
Jwt__Issuer=IdentityHabits.Api
Jwt__ExpiryDays=14
Cors__AllowedOrigins__0=http://localhost:4200
MigrateOnStartup=true

# Frontend (Angular): the API base URL is set at build time in
# frontend/src/environments/environment.production.ts, not via this file.
